{
  "name": "@spark-connect-js/node",
  "version": "0.1.0",
  "description": "Node.js runtime adapter: gRPC transport, Arrow decoding, Buffer handling, async streaming for Spark Connect",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/prustic/spark-connect-js.git",
    "directory": "packages/spark-node"
  },
  "homepage": "https://github.com/prustic/spark-connect-js/tree/main/packages/spark-node",
  "bugs": "https://github.com/prustic/spark-connect-js/issues",
  "keywords": [
    "spark",
    "spark-connect",
    "grpc",
    "arrow",
    "nodejs",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "git clean -xdf .cache .turbo dist *.tsbuildinfo node_modules",
    "test": "node --test $(find dist -name '*.test.js')",
    "test:coverage": "c8 --reporter=lcov --reporter=text --reports-dir=coverage --src=src --exclude='dist/**/*.test.js' node --test $(find dist -name '*.test.js')",
    "lint": "eslint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@spark-connect-js/core": "workspace:*",
    "@spark-connect-js/connect": "workspace:*",
    "@bufbuild/protobuf": "^2.0.0",
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.0",
    "apache-arrow": "^18.0.0"
  },
  "devDependencies": {
    "@spark-connect-js/eslint-config": "workspace:*",
    "@spark-connect-js/typescript-config": "workspace:*",
    "eslint": "catalog:"
  }
}
