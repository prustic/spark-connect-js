{
  "name": "@spark-js/node",
  "version": "0.1.0",
  "description": "Node.js runtime adapter: gRPC transport, Arrow decoding, Buffer handling, async streaming for Spark Connect",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test": "node --test dist/**/*.test.js",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-exclude='**/*.test.js' --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout dist/**/*.test.js",
    "lint": "eslint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@spark-js/core": "workspace:*",
    "@spark-js/connect": "workspace:*",
    "@bufbuild/protobuf": "^2.0.0",
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.0",
    "apache-arrow": "^18.0.0"
  },
  "devDependencies": {
    "@spark-js/eslint-config": "workspace:*",
    "@spark-js/typescript-config": "workspace:*",
    "eslint": "catalog:"
  }
}
