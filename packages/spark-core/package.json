{
  "name": "@spark-connect-js/core",
  "version": "0.1.0",
  "description": "Pure TypeScript core: logical DataFrame API and Spark Connect plan builder — no runtime dependencies",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/prustic/spark-connect-js.git",
    "directory": "packages/spark-core"
  },
  "homepage": "https://github.com/prustic/spark-connect-js/tree/main/packages/spark-core",
  "bugs": "https://github.com/prustic/spark-connect-js/issues",
  "keywords": [
    "spark",
    "spark-connect",
    "dataframe",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "git clean -xdf .cache .turbo dist *.tsbuildinfo node_modules",
    "test": "node --test $(find dist -name '*.test.js')",
    "test:coverage": "c8 --reporter=lcov --reporter=text --reports-dir=coverage --src=src --exclude='dist/**/*.test.js' node --test $(find dist -name '*.test.js')",
    "lint": "eslint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@spark-connect-js/eslint-config": "workspace:*",
    "@spark-connect-js/typescript-config": "workspace:*",
    "@types/node": "^25.3.5",
    "eslint": "catalog:"
  }
}
