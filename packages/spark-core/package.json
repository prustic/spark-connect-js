{
  "name": "@spark-connect-js/core",
  "version": "0.1.0",
  "description": "Pure TypeScript core: logical DataFrame API and Spark Connect plan builder — no runtime dependencies",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test": "node --test $(find dist -name '*.test.js')",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-exclude='**/*.test.js' --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout $(find dist -name '*.test.js')",
    "lint": "eslint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@spark-connect-js/eslint-config": "workspace:*",
    "@spark-connect-js/typescript-config": "workspace:*",
    "@types/node": "^22.19.15",
    "eslint": "catalog:"
  }
}
