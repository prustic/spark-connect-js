{
  "name": "@spark-js/core",
  "version": "0.1.0",
  "description": "Pure TypeScript core: logical DataFrame API and Spark Connect plan builder — no runtime dependencies",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test": "node --test dist/**/*.test.js",
    "lint": "eslint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@spark-js/eslint-config": "workspace:*",
    "@spark-js/typescript-config": "workspace:*",
    "eslint": "catalog:"
  }
}
