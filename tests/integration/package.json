{
  "name": "@spark-connect-js/integration-tests",
  "version": "0.0.0",
  "private": true,
  "description": "Integration tests against a live Spark Connect server",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "clean": "git clean -xdf .cache .turbo dist *.tsbuildinfo node_modules",
    "spark:up": "docker compose up -d --wait",
    "spark:down": "docker compose down",
    "test:integration": "pnpm spark:up && node --test $(find dist -name '*.test.js') && pnpm spark:down",
    "lint": "eslint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@spark-connect-js/node": "workspace:*"
  },
  "devDependencies": {
    "@spark-connect-js/eslint-config": "workspace:*",
    "@spark-connect-js/typescript-config": "workspace:*",
    "@types/node": "^22.19.15",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
